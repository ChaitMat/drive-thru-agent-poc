# Copy to .env and fill in. .env is gitignored.

# ---------- Required ----------
OPENAI_API_KEY=sk-...

# ---------- Optional (defaults shown) ----------
OPENAI_MODEL=gpt-4o-mini

# Voice CLI — faster-whisper ASR
# Model: tiny | base | small | medium | large-v3
# `small` is the recommended drive-thru sweet spot
FASTER_WHISPER_MODEL=base
FASTER_WHISPER_DEVICE=cpu          # cuda for NVIDIA GPUs
FASTER_WHISPER_COMPUTE_TYPE=int8   # int8_float16 or float32 for higher precision

# Voice CLI & Kiosk — Piper TTS voice
# Catalog: https://github.com/rhasspy/piper/blob/master/VOICES.md
PIPER_VOICE=en_US-amy-medium

# Kiosk — startup greeting (printed and spoken when 🚗 Car arrived fires)
KIOSK_GREETING=Welcome to Highway Bites! What would you like to have?
