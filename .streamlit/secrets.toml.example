# Streamlit secrets template.
#
# On Streamlit Community Cloud: paste these into the app dashboard under
#   App → Settings → Secrets   (do NOT commit real keys to the repo).
# For local runs you may instead copy this file to .streamlit/secrets.toml,
# which is gitignored. The kiosk mirrors these into environment variables at
# startup, so the same os.getenv(...) call sites used with .env keep working.

OPENAI_API_KEY = "sk-..."

# Optional (defaults shown)
OPENAI_MODEL = "gpt-4o-mini"
PIPER_VOICE = "en_US-amy-medium"
KIOSK_GREETING = "Welcome to Highway Bites! What would you like to have?"
